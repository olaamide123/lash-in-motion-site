NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-22

# Local seed only (npm run seed:sanity) — never commit the real token
SANITY_API_WRITE_TOKEN=

# Secures POST /api/sanity-webhook (set same value in Sanity webhook header)
